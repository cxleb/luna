{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Luna",
  "scopeName": "source.luna",
  "fileTypes": ["luna"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#imports" },
    { "include": "#keywords" },
    { "include": "#declarations" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#operators" },
    { "include": "#members" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.luna",
          "begin": "//",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.luna" }
          },
          "end": "$\n?"
        }
      ]
    },

    "imports": {
      "patterns": [
        {
          "name": "meta.import.luna",
          "match": "\\b(import)\\b\\s+(\"[^\"]+\")",
          "captures": {
            "1": { "name": "keyword.control.import.luna" },
            "2": { "name": "string.quoted.double.import-path.luna" }
          }
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.luna",
          "match": "\\b(if|else|while|for|in|return|import)\\b"
        },
        {
          "name": "keyword.declaration.luna",
          "match": "\\b(func|struct|interface|extension|init|let|var|const)\\b"
        },
        {
          "name": "variable.language.self.luna",
          "match": "\\bself\\b"
        }
      ]
    },

    "declarations": {
      "patterns": [
        {
          "name": "meta.function.definition.luna",
          "begin": "\\b(func)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(\\()",
          "beginCaptures": {
            "1": { "name": "storage.type.function.luna" },
            "2": { "name": "entity.name.function.luna" },
            "3": { "name": "punctuation.section.parameters.begin.luna" }
          },
          "end": "(\\))\\s*(?::\\s*([A-Za-z_][A-Za-z0-9_]*(?:\\[\\])?|\\[\\][A-Za-z_][A-Za-z0-9_]*))?",
          "endCaptures": {
            "1": { "name": "punctuation.section.parameters.end.luna" },
            "2": { "name": "storage.type.return-type.luna" }
          },
          "patterns": [
            { "include": "#parameters" },
            { "include": "#types" }
          ]
        },
        {
          "name": "meta.constructor.definition.luna",
          "begin": "\\b(init)\\b\\s*(\\()",
          "beginCaptures": {
            "1": { "name": "storage.type.function.constructor.luna" },
            "2": { "name": "punctuation.section.parameters.begin.luna" }
          },
          "end": "(\\))",
          "endCaptures": {
            "1": { "name": "punctuation.section.parameters.end.luna" }
          },
          "patterns": [
            { "include": "#parameters" },
            { "include": "#types" }
          ]
        },
        {
          "name": "meta.struct.definition.luna",
          "match": "\\b(struct)\\b\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.struct.luna" },
            "2": { "name": "entity.name.type.struct.luna" }
          }
        },
        {
          "name": "meta.interface.definition.luna",
          "match": "\\b(interface)\\b\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.interface.luna" },
            "2": { "name": "entity.name.type.interface.luna" }
          }
        },
        {
          "name": "meta.extension.definition.luna",
          "match": "\\b(extension)\\b\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.extension.luna" },
            "2": { "name": "entity.name.type.extension.luna" }
          }
        },
        {
          "name": "meta.variable.declaration.luna",
          "match": "\\b(let|var|const)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?::\\s*([^=;,{\\n]+))?",
          "captures": {
            "1": { "name": "storage.modifier.luna" },
            "2": { "name": "variable.other.readwrite.luna" },
            "3": { "name": "storage.type.annotation.luna" }
          }
        },
        {
          "name": "meta.field.declaration.luna",
          "match": "\\b([a-z_][A-Za-z0-9_]*)\\b\\s*:\\s*([A-Za-z_][A-Za-z0-9_]*|\\[\\][A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "variable.other.member.luna" },
            "2": { "name": "storage.type.luna" }
          }
        }
      ]
    },

    "parameters": {
      "patterns": [
        {
          "name": "meta.parameter.luna",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b\\s*:\\s*([A-Za-z_][A-Za-z0-9_]*|\\[\\][A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "variable.parameter.luna" },
            "2": { "name": "storage.type.parameter.luna" }
          }
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "name": "storage.type.builtin.luna",
          "match": "\\b(int|number|bool|string)\\b"
        },
        {
          "name": "storage.type.array.luna",
          "match": "\\[\\]\\s*([A-Za-z_][A-Za-z0-9_]*)"
        },
        {
          "name": "entity.name.type.luna",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },

    "functions": {
      "patterns": [
        {
          "name": "meta.function.call.luna",
          "match": "\\b([a-z_][A-Za-z0-9_]*)\\b\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.luna" }
          }
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.luna",
          "begin": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.luna" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.luna" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.luna",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.luna",
              "begin": "\\$\\{",
              "beginCaptures": {
                "0": { "name": "punctuation.section.interpolation.begin.luna" }
              },
              "end": "\\}",
              "endCaptures": {
                "0": { "name": "punctuation.section.interpolation.end.luna" }
              },
              "patterns": [
                { "include": "#comments" },
                { "include": "#strings" },
                { "include": "#numbers" },
                { "include": "#booleans" },
                { "include": "#keywords" },
                { "include": "#operators" },
                { "include": "#functions" },
                { "include": "#members" },
                { "include": "#types" }
              ]
            },
            {
              "name": "meta.inline-template.luna",
              "match": "\\{[^{}]+\\}",
              "captures": {
                "0": { "name": "meta.embedded.expression.inline.luna" }
              }
            }
          ]
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.luna",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.luna",
          "match": "\\b\\d+\\b"
        }
      ]
    },

    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.luna",
          "match": "\\b(true|false)\\b"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.luna",
          "match": "="
        },
        {
          "name": "keyword.operator.comparison.luna",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.luna",
          "match": "\\+|-|\\*|/"
        }
      ]
    },

    "members": {
      "patterns": [
        {
          "name": "meta.member.access.luna",
          "match": "\\.\\s*([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "0": { "name": "punctuation.accessor.dot.luna" },
            "1": { "name": "variable.other.property.luna" }
          }
        }
      ]
    }
  }
}