import "std:http";

struct HttpServer {
    a: int,

    func accept(req: Request, res: Response) {
        if req.path == "/hello" {
            res.ok("<p>Hello! ${self.a}</p>");
            self.a = self.a + 1;
        } else {
            res.ok("<p>Hello!</p>");
        }
    }
}

func main() {
    let server = HttpServer{
        a: 0
    };
    let addr = "localhost:7111";
    println("Serving on ${addr}");
    serve(addr, server);
}