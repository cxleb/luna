func main() {
    let a = 20;
    switch a {
        0: {
            assert(a == 0);
        }
        10: {
            assert(a == 10);
        }
        20: {
            assert(a == 20);
        }
    }
    let a = 1;
    switch a {
        0: {
            assert(a == 0);
        }
        1: {
            assert(a == 1);
        }
        2: {
            assert(a == 2);
        }
    }
    a = 1;
    switch a {
        0: {
            assert(a == 0);
        }
        _: {
            assert(a != 0);
        }
    }
    switch a {
        _: {
            assert(true);
        }
    }
    switch a {
    }
}