struct Test {
    a: int,
    b: number,
    c: string,
    d: byte
}

func main() {
    let test1 = Test {
        a: 10,
        b: 10.10,
        c: "Hello!",
        d: 20
    };

    test1.c = "Hello, World!";
    test1.a = 20;

    assert(test1.a == 20);
    assert(test1.b == 10.10);
    assert(test1.c == "Hello, World!");
    let d: byte = 20;
    assert(test1.d == d);
}